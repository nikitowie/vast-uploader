# =============================================================================
# .env.example — Environment variables for vast-comfyui-wan
#
# Copy to .env for local testing (not used in production — set in Vast template)
# None of these should be hardcoded in the Docker image.
# Set them as Vast.ai template environment variables.
# =============================================================================

# ---------------------------------------------------------------------------
# GitHub Actions / Registry
# Set as GitHub Variables (not Secrets) under Settings → Secrets and variables → Variables
# ---------------------------------------------------------------------------
REGISTRY=docker.io
# or: REGISTRY=ghcr.io

IMAGE_NAME=youruser/vast-comfyui-wan
# GHCR example: IMAGE_NAME=yourgithubuser/vast-comfyui-wan

IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# GitHub Actions / Registry credentials
# Set as GitHub Secrets under Settings → Secrets and variables → Secrets
# Not needed for GHCR (uses GITHUB_TOKEN automatically)
# ---------------------------------------------------------------------------
# DOCKER_USERNAME=youruser
# DOCKER_PASSWORD=your_docker_hub_access_token

# ---------------------------------------------------------------------------
# CivitAI API token — REQUIRED for SmoothMix model downloads
#
# Get your token at: https://civitai.com/user/account → API Keys
# Set this in Vast.ai template env vars (not in the Docker image)
# ---------------------------------------------------------------------------
CIVITAI_API_TOKEN=f41f91bf884e1736b390182cbf138719

# ---------------------------------------------------------------------------
# Runtime — ComfyUI + handler behavior
# All have defaults in Dockerfile; only override if needed
# ---------------------------------------------------------------------------

# Internal ComfyUI port (do not change unless you have a conflict)
COMFYUI_PORT=8188

# Port exposed by the serverless handler (Vast.ai expects 8000)
HANDLER_PORT=8000

# Where ComfyUI model cache lives.
# Override to /workspace/models if using a Vast persistent network volume
# (models persist between cold starts — strongly recommended)
MODEL_CACHE_DIR=/opt/ComfyUI/models

# LoRA download directory
LORA_DIR=/opt/ComfyUI/models/loras

# ComfyUI output dir
OUTPUT_DIR=/opt/ComfyUI/output

# Max seconds to wait for one inference job before returning 504
MAX_WAIT_SECONDS=600

# Set to "1" to skip model downloads at container start (dev/debug only)
SKIP_PROVISIONING=0

# Extra CLI args passed to ComfyUI main.py (optional)
# Examples: --highvram  --fp8_e4m3fn  --use-quad-cross-attention
# COMFYUI_ARGS=

# ---------------------------------------------------------------------------
# HuggingFace token (optional — only needed for private/gated models)
# All models in provisioning.sh are public; leave unset unless you add gated ones
# ---------------------------------------------------------------------------
# HF_TOKEN=hf_...
